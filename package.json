{
  "name": "revela",
  "version": "0.1.0",
  "description": "OpenCode plugin that turns AI into an HTML slide deck generator",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "plugins/",
    "lib/",
    "tools/",
    "skill/",
    "designs/",
    "domains/",
    "index.ts",
    "scripts/"
  ],
  "scripts": {
    "postinstall": "node scripts/seed.js"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "dependencies": {
    "@xmldom/xmldom": "latest",
    "fflate": "latest",
    "jimp": "latest",
    "mammoth": "latest",
    "unpdf": "latest"
  }
}
